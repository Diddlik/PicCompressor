<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style Selector="TextBlock.h1">
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource PcText}" />
  </Style>

  <Style Selector="TextBlock.h2">
    <Setter Property="FontSize" Value="13.5" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource PcText}" />
  </Style>

  <Style Selector="TextBlock.sub">
    <Setter Property="FontSize" Value="12.5" />
    <Setter Property="Foreground" Value="{DynamicResource PcDim}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style Selector="TextBlock.hint">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Foreground" Value="{DynamicResource PcFaint}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style Selector="TextBlock.mono">
    <Setter Property="FontFamily" Value="{StaticResource PcMono}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Foreground" Value="{DynamicResource PcDim}" />
  </Style>

  <Style Selector="TextBlock.caps">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource PcFaint}" />
  </Style>

  <!-- Karte: Panel-Fläche mit Rahmen, wie die Vorlagen-Panels. -->
  <Style Selector="Border.card">
    <Setter Property="Background" Value="{DynamicResource PcPanel}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PcBorder}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource PcCardRadius}" />
    <Setter Property="Padding" Value="16,15" />
  </Style>

  <Style Selector="Border.row">
    <Setter Property="Background" Value="{DynamicResource PcPanel2}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PcBorderSoft}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="9" />
    <Setter Property="Padding" Value="10,9" />
  </Style>

  <Style Selector="Button.primary">
    <Setter Property="Background" Value="{DynamicResource PcAccent}" />
    <Setter Property="Foreground" Value="#FFFFFF" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="{StaticResource PcControlRadius}" />
    <Setter Property="Padding" Value="16,10" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource PcAccentStrong}" />
    <Setter Property="TextElement.Foreground" Value="#FFFFFF" />
  </Style>

  <Style Selector="Button.secondary">
    <Setter Property="Background" Value="{DynamicResource PcPanel2}" />
    <Setter Property="Foreground" Value="{DynamicResource PcText}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PcBorder}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource PcControlRadius}" />
    <Setter Property="Padding" Value="13,8" />
    <Setter Property="FontSize" Value="12.5" />
  </Style>
  <Style Selector="Button.secondary:pointerover /template/ ContentPresenter">
    <Setter Property="BorderBrush" Value="{DynamicResource PcAccent}" />
    <Setter Property="Background" Value="{DynamicResource PcPanel2}" />
    <Setter Property="TextElement.Foreground" Value="{DynamicResource PcText}" />
  </Style>

  <!-- Kompakte Textaktion für Zeilenbefehle (MP-002); dezent bis zum Zeigerkontakt. -->
  <Style Selector="Button.link">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource PcAccent}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="4,2" />
    <Setter Property="FontSize" Value="11.5" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style Selector="Button.link:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource PcAccentSoft}" />
    <Setter Property="TextElement.Foreground" Value="{DynamicResource PcAccentStrong}" />
  </Style>
  <Style Selector="Button.link:disabled">
    <Setter Property="Opacity" Value="0.4" />
  </Style>

  <!-- Navigationsschiene (Prototype): 52px-Zeile, Icon-Chip wird bei Auswahl lime, Zeile ink. -->
  <Style Selector="RadioButton.nav">
    <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="root" Background="Transparent" CornerRadius="16" Padding="12,0" MinHeight="52">
          <ContentPresenter Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            TextElement.Foreground="{TemplateBinding Foreground}"
                            VerticalAlignment="Center" />
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="RadioButton.nav:pointerover /template/ Border#root">
    <Setter Property="Background" Value="{DynamicResource FieldBrush}" />
  </Style>
  <Style Selector="RadioButton.nav:checked /template/ Border#root">
    <Setter Property="Background" Value="{DynamicResource InkBrush}" />
  </Style>
  <Style Selector="RadioButton.nav:checked">
    <Setter Property="Foreground" Value="{DynamicResource InkTextInverse}" />
  </Style>
  <!-- Icon-Chip in der Zeile. -->
  <Style Selector="Border.navchip">
    <Setter Property="Width" Value="34" />
    <Setter Property="Height" Value="34" />
    <Setter Property="CornerRadius" Value="11" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <!-- Segment-Umschalter (Engine, Chroma). -->
  <Style Selector="RadioButton.segment">
    <Setter Property="Foreground" Value="{DynamicResource PcDim}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="root" Background="Transparent" CornerRadius="7" Padding="10,7">
          <ContentPresenter Content="{TemplateBinding Content}"
                            TextElement.Foreground="{TemplateBinding Foreground}"
                            HorizontalAlignment="Center" />
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="RadioButton.segment:checked /template/ Border#root">
    <Setter Property="Background" Value="{DynamicResource PcAccent}" />
  </Style>
  <Style Selector="RadioButton.segment:checked">
    <Setter Property="Foreground" Value="#FFFFFF" />
  </Style>

  <Style Selector="Border.segmentHost">
    <Setter Property="Background" Value="{DynamicResource PcPanel2}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PcBorderSoft}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="9" />
    <Setter Property="Padding" Value="3" />
  </Style>

  <Style Selector="RadioButton.option">
    <Setter Property="Foreground" Value="{DynamicResource PcText}" />
    <Setter Property="Padding" Value="8,0,0,0" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
  </Style>

  <Style Selector="TextBox">
    <Setter Property="Background" Value="{DynamicResource FieldBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource InkBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
    <Setter Property="BorderThickness" Value="2" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Padding" Value="11,8" />
  </Style>

  <!-- Zahleneingabe (MinSaving, Timeouts …) im Bento-Look. -->
  <Style Selector="NumericUpDown">
    <Setter Property="Background" Value="{DynamicResource FieldBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource InkBrush}" />
    <Setter Property="BorderThickness" Value="2" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
    <Setter Property="FontFamily" Value="{DynamicResource PcMonoFont}" />
  </Style>

  <Style Selector="Border.pill">
    <Setter Property="CornerRadius" Value="20" />
    <Setter Property="Padding" Value="9,3" />
  </Style>

  <!-- ============================================================= -->
  <!-- Redesign "Cozy-neon bento" — gemeinsame Steuerelemente (S2).    -->
  <!-- docs/UI - refinement/01-design-system.md. Neue Klassen; die     -->
  <!-- alten Pc*-Stile oben bleiben, bis alle Views migriert sind.     -->
  <!-- ============================================================= -->

  <!-- Standardschrift der App (S0/S1). -->
  <Style Selector="Window">
    <Setter Property="FontFamily" Value="{DynamicResource PcUiFont}" />
  </Style>

  <!-- Typografie -->
  <Style Selector="TextBlock.pageTitle">
    <Setter Property="FontFamily" Value="{DynamicResource PcDisplayFont}" />
    <Setter Property="FontSize" Value="30" />
    <Setter Property="FontWeight" Value="ExtraBold" />
    <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
  </Style>
  <Style Selector="TextBlock.heroTitle">
    <Setter Property="FontFamily" Value="{DynamicResource PcDisplayFont}" />
    <Setter Property="FontSize" Value="32" />
    <Setter Property="FontWeight" Value="ExtraBold" />
    <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
  </Style>
  <Style Selector="TextBlock.cardTitle">
    <Setter Property="FontFamily" Value="{DynamicResource PcDisplayFont}" />
    <Setter Property="FontSize" Value="18.5" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
  </Style>
  <Style Selector="TextBlock.bodyText">
    <Setter Property="FontFamily" Value="{DynamicResource PcUiFont}" />
    <Setter Property="FontSize" Value="13.5" />
    <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>
  <Style Selector="TextBlock.muted">
    <Setter Property="FontFamily" Value="{DynamicResource PcUiFont}" />
    <Setter Property="FontSize" Value="13.5" />
    <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>
  <Style Selector="TextBlock.captionText">
    <Setter Property="FontSize" Value="12.5" />
    <Setter Property="Foreground" Value="{DynamicResource MutedText2Brush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>
  <Style Selector="TextBlock.capsLabel">
    <Setter Property="FontSize" Value="11.5" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="LetterSpacing" Value="0.6" />
    <Setter Property="Foreground" Value="{DynamicResource MutedText2Brush}" />
  </Style>
  <Style Selector="TextBlock.monoNum">
    <Setter Property="FontFamily" Value="{DynamicResource PcMonoFont}" />
    <Setter Property="FontSize" Value="12.5" />
    <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
  </Style>
  <Style Selector="TextBlock.bigStat">
    <Setter Property="FontFamily" Value="{DynamicResource PcMonoFont}" />
    <Setter Property="FontSize" Value="30" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
  </Style>

  <!-- Flächen -->
  <Style Selector="Border.card">
    <Setter Property="Background" Value="{DynamicResource PaperBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource InkBrush}" />
    <Setter Property="BorderThickness" Value="2" />
    <Setter Property="CornerRadius" Value="{StaticResource CardRadius}" />
    <Setter Property="Padding" Value="21" />
    <Setter Property="BoxShadow" Value="5 6 0 0 #E617140E" />
  </Style>
  <Style Selector="Border.tile">
    <Setter Property="BorderBrush" Value="{DynamicResource InkBrush}" />
    <Setter Property="BorderThickness" Value="2" />
    <Setter Property="CornerRadius" Value="{StaticResource TileRadius}" />
    <Setter Property="Padding" Value="18" />
    <Setter Property="BoxShadow" Value="4 5 0 0 #E617140E" />
  </Style>
  <!-- Eingezogene Zeile (Queue-/Info-Zeilen). -->
  <Style Selector="Border.insetRow">
    <Setter Property="Background" Value="{DynamicResource FieldBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource InkBrush}" />
    <Setter Property="BorderThickness" Value="2" />
    <Setter Property="CornerRadius" Value="16" />
    <Setter Property="Padding" Value="12,10" />
  </Style>

  <!-- Primärbutton .cta — eigenes Template, weil nur ein Border BoxShadow zeichnet. -->
  <Style Selector="Button.cta">
    <Setter Property="Background" Value="{DynamicResource LimeBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource InkBrush}" />
    <Setter Property="BorderThickness" Value="2.5" />
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="Padding" Value="20,11" />
    <Setter Property="MinHeight" Value="44" />
    <Setter Property="FontFamily" Value="{DynamicResource PcDisplayFont}" />
    <Setter Property="FontSize" Value="14.5" />
    <Setter Property="FontWeight" Value="ExtraBold" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="RenderTransform" Value="none" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="shell" Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}" BoxShadow="4 4 0 0 #E617140E">
          <ContentPresenter Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            TextElement.Foreground="{TemplateBinding Foreground}"
                            Padding="{TemplateBinding Padding}"
                            HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="Button.cta:pointerover /template/ Border#shell">
    <Setter Property="BoxShadow" Value="5 5 0 0 #E617140E" />
  </Style>
  <Style Selector="Button.cta:pointerover">
    <Setter Property="RenderTransform" Value="translateY(-1px)" />
  </Style>
  <Style Selector="Button.cta:disabled /template/ Border#shell">
    <Setter Property="Background" Value="#EDE7DA" />
    <Setter Property="BoxShadow" Value="none" />
  </Style>
  <Style Selector="Button.cta:disabled /template/ ContentPresenter">
    <Setter Property="TextElement.Foreground" Value="#B0A892" />
  </Style>

  <!-- Sekundärbutton .ghost (+ Varianten) -->
  <Style Selector="Button.ghost">
    <Setter Property="Background" Value="{DynamicResource PaperBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource InkBrush}" />
    <Setter Property="BorderThickness" Value="2" />
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="Padding" Value="15,9" />
    <Setter Property="MinHeight" Value="38" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource CanvasBrush}" />
    <Setter Property="TextElement.Foreground" Value="{DynamicResource InkBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource InkBrush}" />
  </Style>
  <Style Selector="Button.ghost.violet:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource VioletSoftBrush}" />
  </Style>
  <Style Selector="Button.ghost.coral:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource CoralSoftBrush}" />
  </Style>
  <Style Selector="Button.ghost.lime:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource LimeBrush}" />
  </Style>
  <Style Selector="Button.ghost:disabled">
    <Setter Property="Opacity" Value="0.45" />
  </Style>

  <!-- Segment-Umschalter (Ink-Auswahl auf Canvas-Pille). -->
  <Style Selector="Border.segmentHost">
    <Setter Property="Background" Value="{DynamicResource CanvasBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource InkBrush}" />
    <Setter Property="BorderThickness" Value="2" />
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="Padding" Value="5" />
  </Style>
  <Style Selector="RadioButton.segment">
    <Setter Property="Foreground" Value="{DynamicResource MutedText2Brush}" />
    <Setter Property="FontSize" Value="12.5" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="root" Background="Transparent" CornerRadius="999" Padding="12,7">
          <ContentPresenter Content="{TemplateBinding Content}"
                            TextElement.Foreground="{TemplateBinding Foreground}"
                            HorizontalAlignment="Center" />
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="RadioButton.segment:checked /template/ Border#root">
    <Setter Property="Background" Value="{DynamicResource InkBrush}" />
  </Style>
  <Style Selector="RadioButton.segment:checked">
    <Setter Property="Foreground" Value="{DynamicResource InkTextInverse}" />
  </Style>

  <!-- Auswahlkarte (gestyltes RadioButton) mit Ring + Titel/Beschreibung. -->
  <Style Selector="RadioButton.optioncard">
    <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="root" Background="{DynamicResource PaperBrush}"
                BorderBrush="{DynamicResource HairlineBrush}" BorderThickness="2"
                CornerRadius="16" Padding="14,12">
          <Grid ColumnDefinitions="22,14,*" VerticalAlignment="Center">
            <Border Name="ring" Grid.Column="0" Width="22" Height="22" CornerRadius="999"
                    BorderBrush="#C9C1B0" BorderThickness="2" Background="Transparent"
                    VerticalAlignment="Center">
              <Ellipse Name="dot" Width="10" Height="10" Fill="{DynamicResource LimeBrush}"
                       IsVisible="False" />
            </Border>
            <ContentPresenter Grid.Column="2"
                              Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              TextElement.Foreground="{TemplateBinding Foreground}"
                              VerticalAlignment="Center" />
          </Grid>
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="RadioButton.optioncard:pointerover /template/ Border#root">
    <Setter Property="BorderBrush" Value="{DynamicResource InkBrush}" />
  </Style>
  <Style Selector="RadioButton.optioncard:checked /template/ Border#root">
    <Setter Property="BorderBrush" Value="{DynamicResource InkBrush}" />
    <Setter Property="Background" Value="#29B9EE43" />
  </Style>
  <Style Selector="RadioButton.optioncard:checked /template/ Border#ring">
    <Setter Property="BorderBrush" Value="{DynamicResource InkBrush}" />
  </Style>
  <Style Selector="RadioButton.optioncard:checked /template/ Ellipse#dot">
    <Setter Property="IsVisible" Value="True" />
  </Style>

  <!-- Kippschalter: eigenes ToggleButton-Template (48×28). -->
  <Style Selector="ToggleButton.switch">
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="track" Width="48" Height="28" CornerRadius="999"
                Background="#EDE7DA" BorderBrush="{DynamicResource InkBrush}" BorderThickness="2">
          <Ellipse Name="knob" Width="20" Height="20" Fill="#FFFFFF"
                   Stroke="{DynamicResource InkBrush}" StrokeThickness="2"
                   HorizontalAlignment="Left" VerticalAlignment="Center" Margin="2,0,0,0">
            <Ellipse.RenderTransform>
              <TranslateTransform X="0" />
            </Ellipse.RenderTransform>
          </Ellipse>
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="ToggleButton.switch:checked /template/ Border#track">
    <Setter Property="Background" Value="{DynamicResource LimeBrush}" />
  </Style>
  <Style Selector="ToggleButton.switch:checked /template/ Ellipse#knob">
    <Setter Property="RenderTransform" Value="translateX(20px)" />
  </Style>

  <!-- Slider: Ink-Akzent. -->
  <Style Selector="Slider">
    <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
  </Style>
  <Style Selector="Slider /template/ Track /template/ RepeatButton#PART_DecreaseButton /template/ Border">
    <Setter Property="Background" Value="{DynamicResource InkBrush}" />
  </Style>
  <Style Selector="Slider /template/ Thumb /template/ Border">
    <Setter Property="Background" Value="{DynamicResource InkBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource InkBrush}" />
  </Style>

  <!-- Eingaben -->
  <Style Selector="TextBox.field">
    <Setter Property="Background" Value="{DynamicResource FieldBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource InkBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
    <Setter Property="BorderThickness" Value="2" />
    <Setter Property="CornerRadius" Value="13" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Padding" Value="11,8" />
  </Style>
  <Style Selector="TextBox.field.mono">
    <Setter Property="FontFamily" Value="{DynamicResource PcMonoFont}" />
  </Style>

  <!-- Pillen/Badges (mono, Ink-Rahmen) -->
  <Style Selector="Border.badge">
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="BorderBrush" Value="{DynamicResource InkBrush}" />
    <Setter Property="BorderThickness" Value="2" />
    <Setter Property="Padding" Value="10,3" />
    <Setter Property="Background" Value="{DynamicResource NeutralPillBrush}" />
  </Style>
  <Style Selector="Border.badge > TextBlock">
    <Setter Property="FontFamily" Value="{DynamicResource PcMonoFont}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
  </Style>
  <Style Selector="Border.badge.lime">
    <Setter Property="Background" Value="{DynamicResource LimeBrush}" />
  </Style>
  <Style Selector="Border.badge.violet">
    <Setter Property="Background" Value="{DynamicResource VioletSoftBrush}" />
  </Style>
  <Style Selector="Border.badge.mint">
    <Setter Property="Background" Value="{DynamicResource MintTileBrush}" />
  </Style>

</Styles>
