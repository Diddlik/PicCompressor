<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Farbrollen der UI-Referenzvorlage (docs/UI/PicCompressor.html), aus oklch nach sRGB konvertiert. -->
  <ResourceDictionary.ThemeDictionaries>

    <ResourceDictionary x:Key="Dark">
      <SolidColorBrush x:Key="PcBg" Color="#101318" />
      <SolidColorBrush x:Key="PcPanel" Color="#191C22" />
      <SolidColorBrush x:Key="PcPanel2" Color="#22252C" />
      <SolidColorBrush x:Key="PcElev" Color="#2B2F37" />
      <SolidColorBrush x:Key="PcBorder" Color="#34383F" />
      <SolidColorBrush x:Key="PcBorderSoft" Color="#282B32" />
      <SolidColorBrush x:Key="PcText" Color="#F0F2F4" />
      <SolidColorBrush x:Key="PcDim" Color="#A5A8AE" />
      <SolidColorBrush x:Key="PcFaint" Color="#74777F" />
      <SolidColorBrush x:Key="PcAccent" Color="#6895F4" />
      <SolidColorBrush x:Key="PcAccentStrong" Color="#5381E6" />
      <SolidColorBrush x:Key="PcAccentSoft" Color="#24324F" />
      <SolidColorBrush x:Key="PcTrack" Color="#303339" />
      <SolidColorBrush x:Key="PcSuccess" Color="#59C886" />
      <SolidColorBrush x:Key="PcSuccessSoft" Color="#183E27" />
      <SolidColorBrush x:Key="PcError" Color="#FD736D" />
      <SolidColorBrush x:Key="PcErrorSoft" Color="#5D2725" />
      <SolidColorBrush x:Key="PcWarn" Color="#F0BA59" />
      <SolidColorBrush x:Key="PcWarnSoft" Color="#4E3914" />
    </ResourceDictionary>

    <ResourceDictionary x:Key="Light">
      <SolidColorBrush x:Key="PcBg" Color="#F2F3F6" />
      <SolidColorBrush x:Key="PcPanel" Color="#FDFDFF" />
      <SolidColorBrush x:Key="PcPanel2" Color="#EEF0F4" />
      <SolidColorBrush x:Key="PcElev" Color="#FFFFFF" />
      <SolidColorBrush x:Key="PcBorder" Color="#D9DBDF" />
      <SolidColorBrush x:Key="PcBorderSoft" Color="#E6E8EB" />
      <SolidColorBrush x:Key="PcText" Color="#252930" />
      <SolidColorBrush x:Key="PcDim" Color="#5A5E65" />
      <SolidColorBrush x:Key="PcFaint" Color="#83868E" />
      <SolidColorBrush x:Key="PcAccent" Color="#406BCE" />
      <SolidColorBrush x:Key="PcAccentStrong" Color="#2F5BC2" />
      <SolidColorBrush x:Key="PcAccentSoft" Color="#DAE8FF" />
      <SolidColorBrush x:Key="PcTrack" Color="#DCDEE2" />
      <SolidColorBrush x:Key="PcSuccess" Color="#00884B" />
      <SolidColorBrush x:Key="PcSuccessSoft" Color="#C9F4D7" />
      <SolidColorBrush x:Key="PcError" Color="#C92F33" />
      <SolidColorBrush x:Key="PcErrorSoft" Color="#FFD7D0" />
      <SolidColorBrush x:Key="PcWarn" Color="#A87600" />
      <SolidColorBrush x:Key="PcWarnSoft" Color="#FFEABA" />
    </ResourceDictionary>

  </ResourceDictionary.ThemeDictionaries>

  <!-- ============================================================= -->
  <!-- Redesign "Cozy-neon bento" (docs/UI - refinement/01-design-system.md). -->
  <!-- Light ist die ausgelieferte Gestaltung; Dark ist Folgearbeit und -->
  <!-- überschreibt diese Tokens später über die ThemeDictionaries. -->
  <!-- ============================================================= -->

  <!-- Schriften: gebündelte OFL-Fonts, keine Systemabhängigkeit. -->
  <FontFamily x:Key="PcDisplayFont">avares://PicCompressor.Gui/Assets/Fonts/Bricolage_Grotesque/BricolageGrotesque-VariableFont_opsz,wdth,wght.ttf#Bricolage Grotesque</FontFamily>
  <FontFamily x:Key="PcUiFont">avares://PicCompressor.Gui/Assets/Fonts/Space_Grotesk/SpaceGrotesk-VariableFont_wght.ttf#Space Grotesk</FontFamily>
  <FontFamily x:Key="PcMonoFont">avares://PicCompressor.Gui/Assets/Fonts/Space_Mono/SpaceMono-Regular.ttf#Space Mono</FontFamily>
  <!-- Altbestand bis alle Views migriert sind (S1-Konvention in TASKS.md). -->
  <FontFamily x:Key="PcMono">avares://PicCompressor.Gui/Assets/Fonts/Space_Mono/SpaceMono-Regular.ttf#Space Mono</FontFamily>
  <CornerRadius x:Key="PcCardRadius">11</CornerRadius>
  <CornerRadius x:Key="PcControlRadius">8</CornerRadius>

  <!-- Farb-Tokens -->
  <SolidColorBrush x:Key="CanvasBrush" Color="#F1ECE1" />
  <SolidColorBrush x:Key="PaperBrush" Color="#FFFFFF" />
  <SolidColorBrush x:Key="InkBrush" Color="#17140E" />
  <SolidColorBrush x:Key="InkTextInverse" Color="#F1ECE1" />
  <SolidColorBrush x:Key="LimeBrush" Color="#B9EE43" />
  <SolidColorBrush x:Key="VioletBrush" Color="#6E5BF2" />
  <SolidColorBrush x:Key="VioletSoftBrush" Color="#EDE9FF" />
  <SolidColorBrush x:Key="CoralBrush" Color="#FF6A45" />
  <SolidColorBrush x:Key="CoralSoftBrush" Color="#FFE4DC" />
  <SolidColorBrush x:Key="MintTileBrush" Color="#E4F7C8" />
  <SolidColorBrush x:Key="MutedTextBrush" Color="#A49B88" />
  <SolidColorBrush x:Key="MutedText2Brush" Color="#8A8272" />
  <SolidColorBrush x:Key="FieldBrush" Color="#F7F4EC" />
  <SolidColorBrush x:Key="HairlineBrush" Color="#E3DDCF" />
  <!-- Zustandsfarben aus den View-Dokumenten. -->
  <SolidColorBrush x:Key="NeutralPillBrush" Color="#EDE7DA" />
  <SolidColorBrush x:Key="CoralTextBrush" Color="#C0492C" />
  <SolidColorBrush x:Key="StageBrush" Color="#E7E1D4" />

  <!-- Eckenradien -->
  <CornerRadius x:Key="CardRadius">24</CornerRadius>
  <CornerRadius x:Key="TileRadius">22</CornerRadius>
  <CornerRadius x:Key="InputRadius">13</CornerRadius>
  <CornerRadius x:Key="ModalRadius">28</CornerRadius>
  <CornerRadius x:Key="PillRadius">999</CornerRadius>

  <!-- Canvas-Aura (dekorativ) — zwei Radialverläufe über der Leinwand, S3 nutzt sie. -->
  <RadialGradientBrush x:Key="AuraLimeBrush" GradientOrigin="10%,4%" Center="10%,4%"
                       RadiusX="42%" RadiusY="42%">
    <GradientStop Offset="0" Color="#38B9EE43" />
    <GradientStop Offset="1" Color="#00B9EE43" />
  </RadialGradientBrush>
  <RadialGradientBrush x:Key="AuraVioletBrush" GradientOrigin="92%,96%" Center="92%,96%"
                       RadiusX="46%" RadiusY="46%">
    <GradientStop Offset="0" Color="#296E5BF2" />
    <GradientStop Offset="1" Color="#006E5BF2" />
  </RadialGradientBrush>
</ResourceDictionary>
