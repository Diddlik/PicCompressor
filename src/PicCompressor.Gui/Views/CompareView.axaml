<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PicCompressor.Gui.ViewModels"
             xmlns:l="using:PicCompressor.Gui.Localization"
             x:Class="PicCompressor.Gui.Views.CompareView"
             x:DataType="vm:CompareViewModel">

  <!-- Raster statt gestapelter Liste: die Vorschau bekommt die Sternzeile und damit allen
       Platz, den Kopfzeile, Bedienung und Ergebnisliste übrig lassen. Eine feste Höhe ließe
       das Bild unabhängig von der Fenstergröße klein. Der Abstand steckt in den Rändern der
       Kinder, nicht in RowSpacing, damit ausgeblendete Zeilen keine Lücke hinterlassen. -->
  <Grid Margin="20" RowDefinitions="Auto,Auto,*,Auto,Auto">

    <StackPanel Grid.Row="0" Spacing="2" Margin="0,0,0,14">
      <TextBlock Classes="h1" Text="{l:Localize Cmp_Title}" />
      <TextBlock Classes="sub" Text="{l:Localize Cmp_Subtitle}" />
    </StackPanel>

    <!-- Ohne validiertes, veröffentlichtes Ergebnis gibt es nichts zu vergleichen. -->
    <Border Grid.Row="1" Classes="card" Margin="0,0,0,14"
            IsVisible="{Binding !HasCandidates}">
      <TextBlock Classes="sub" Text="{l:Localize Cmp_NoCandidates}" />
    </Border>

    <Border Grid.Row="2" MinHeight="180" Margin="0,0,0,14" CornerRadius="12"
            ClipToBounds="True" IsVisible="{Binding HasSelection}"
            BorderBrush="{DynamicResource PcBorder}" BorderThickness="1"
            Background="{DynamicResource PcPanel2}">
      <!-- Fokussierbar, damit Schwenken auch ohne Zeigegerät möglich ist. -->
      <Grid x:Name="CompareSurface" Focusable="True"
            AutomationProperties.Name="{l:Localize Cmp_PreviewName}">

        <Image x:Name="CompressedImage" Source="{Binding CompressedPreview}"
               Stretch="Uniform" RenderTransformOrigin="50%,50%" />

        <!-- Obere Schicht: deckt die volle Fläche wie die untere, wird aber vom Regler
             beschnitten. Das Beschneiden sitzt am Rahmen, nicht am Bild, damit die
             Teilerkante beim Zoomen an ihrer Stelle bleibt. Dieselbe Transformation auf
             beiden Seiten hält die Ansicht synchron. -->
        <Panel x:Name="OriginalPane">
          <Image x:Name="OriginalImage" Source="{Binding OriginalPreview}"
                 Stretch="Uniform" RenderTransformOrigin="50%,50%" />
        </Panel>

        <!-- Trennkante zwischen den Schichten. Sie liegt über beliebigen Bildinhalten,
             deshalb eine feste helle Linie mit dunklem Schein statt einer Themenfarbe:
             nur so bleibt sie auf hellen wie dunklen Bildern sichtbar. Sie nimmt keine
             Zeigereingaben an, damit das Schwenken darunter weiterläuft. -->
        <Border x:Name="DividerLine" Width="3" HorizontalAlignment="Left"
                IsHitTestVisible="False" IsVisible="{Binding HasPreview}"
                Background="#F2FFFFFF" BoxShadow="0 0 5 0 #A6000000" />

        <TextBlock Classes="hint" HorizontalAlignment="Center" VerticalAlignment="Center"
                   TextAlignment="Center" IsVisible="{Binding IsPreviewLoading}"
                   Text="{l:Localize Cmp_PreviewPending}" />
        <TextBlock Classes="hint" HorizontalAlignment="Center" VerticalAlignment="Center"
                   TextAlignment="Center" IsVisible="{Binding HasPreviewError}"
                   Text="{Binding PreviewError}" />

        <Border Classes="pill" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="12"
                Background="{DynamicResource PcPanel}">
          <TextBlock Classes="mono" Text="{l:Localize Cmp_Original}" />
        </Border>
        <Border Classes="pill" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12"
                Background="{DynamicResource PcAccent}">
          <TextBlock Classes="mono" Foreground="#FFFFFF" Text="{l:Localize Cmp_Compressed}" />
        </Border>
      </Grid>
    </Border>

    <StackPanel Grid.Row="3" Spacing="14" Margin="0,0,0,14"
                IsVisible="{Binding HasSelection}">

      <StackPanel Spacing="6">
        <TextBlock Classes="caps" Text="{l:Localize Cmp_Divider}" />
        <Slider Minimum="0" Maximum="1" Value="{Binding DividerFraction}"
                SmallChange="0.02" LargeChange="0.1"
                AutomationProperties.Name="{l:Localize Cmp_Divider}" />
      </StackPanel>

      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Classes="caps" VerticalAlignment="Center" Text="{l:Localize Cmp_Zoom}" />
        <Button Command="{Binding ZoomOutCommand}" Content="{l:Localize Cmp_ZoomOut}"
                AutomationProperties.Name="{l:Localize Cmp_ZoomOut}" />
        <Button Command="{Binding ZoomInCommand}" Content="{l:Localize Cmp_ZoomIn}"
                AutomationProperties.Name="{l:Localize Cmp_ZoomIn}" />
        <Button Command="{Binding ActualSizeCommand}" Content="{l:Localize Cmp_ActualSize}"
                AutomationProperties.Name="{l:Localize Cmp_ActualSize}" />
        <Button Command="{Binding ResetViewCommand}" Content="{l:Localize Cmp_ResetView}"
                AutomationProperties.Name="{l:Localize Cmp_ResetView}" />
        <TextBlock Classes="mono" VerticalAlignment="Center" Text="{Binding ZoomLabel}" />
        <TextBlock Classes="hint" VerticalAlignment="Center"
                   IsVisible="{Binding IsPreviewDownscaled}"
                   Text="{l:Localize Cmp_PreviewDownscaled}" />
      </StackPanel>

      <!-- Vorher/Nachher-Tabelle (Issue #4); nur Groesse, Format, Masse und Einsparung. -->
      <Border Classes="card" IsVisible="{Binding HasComparison}">
        <StackPanel Spacing="10">
          <TextBlock Classes="h2" Text="{Binding Selected.FileName}" />
          <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto,Auto"
                RowSpacing="6" ColumnSpacing="12">
            <TextBlock Grid.Row="0" Grid.Column="0" Classes="caps"
                       Text="{l:Localize Cmp_TblAttribute}" />
            <TextBlock Grid.Row="0" Grid.Column="1" Classes="caps"
                       Text="{l:Localize Cmp_TblBefore}" />
            <TextBlock Grid.Row="0" Grid.Column="2" Classes="caps"
                       Text="{l:Localize Cmp_TblAfter}" />

            <TextBlock Grid.Row="1" Grid.Column="0" Classes="hint"
                       Text="{l:Localize Cmp_TblFormat}" />
            <TextBlock Grid.Row="1" Grid.Column="1" Classes="mono" Text="{Binding BeforeFormat}" />
            <TextBlock Grid.Row="1" Grid.Column="2" Classes="mono" Text="{Binding AfterFormat}" />

            <TextBlock Grid.Row="2" Grid.Column="0" Classes="hint"
                       Text="{l:Localize Cmp_TblSize}" />
            <TextBlock Grid.Row="2" Grid.Column="1" Classes="mono" Text="{Binding BeforeSize}" />
            <TextBlock Grid.Row="2" Grid.Column="2" Classes="mono" Text="{Binding AfterSize}" />

            <TextBlock Grid.Row="3" Grid.Column="0" Classes="hint"
                       Text="{l:Localize Cmp_TblDimensions}" />
            <TextBlock Grid.Row="3" Grid.Column="1" Classes="mono" Text="{Binding Dimensions}" />
            <TextBlock Grid.Row="3" Grid.Column="2" Classes="mono" Text="{Binding Dimensions}" />
          </Grid>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Classes="caps" VerticalAlignment="Center"
                       Text="{l:Localize Cmp_TblSavings}" />
            <TextBlock Classes="mono" FontWeight="SemiBold"
                       Foreground="{DynamicResource PcAccent}" Text="{Binding SavingsText}" />
            <TextBlock Classes="hint" VerticalAlignment="Center"
                       Text="{l:Localize Cmp_TblEstimate}" IsVisible="{Binding IsEstimate}" />
          </StackPanel>
        </StackPanel>
      </Border>
    </StackPanel>

    <StackPanel Grid.Row="4" Spacing="8" IsVisible="{Binding HasCandidates}">
        <TextBlock Classes="caps" Text="{l:Localize Cmp_Results}" />
        <ListBox ItemsSource="{Binding Candidates}" SelectedItem="{Binding Selected}"
                 Background="Transparent" BorderThickness="0" MaxHeight="200"
                 AutomationProperties.Name="{l:Localize Cmp_CandidatesName}">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:QueueItemViewModel">
              <StackPanel Spacing="2" AutomationProperties.Name="{Binding AccessibleSummary}">
                <TextBlock Text="{Binding FileName}" FontSize="12.5"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Classes="mono" Text="{Binding SizeSummary}" />
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
      </ListBox>
    </StackPanel>

  </Grid>
</UserControl>
