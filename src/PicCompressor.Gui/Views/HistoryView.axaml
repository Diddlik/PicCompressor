<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PicCompressor.Gui.ViewModels"
             xmlns:l="using:PicCompressor.Gui.Localization"
             x:Class="PicCompressor.Gui.Views.HistoryView"
             x:DataType="vm:HistoryViewModel">

  <ScrollViewer Padding="2,2,12,16">
    <StackPanel Spacing="16">

      <!-- Kopf: Titel + Zusammenfassung, rechts Suche + Verlauf leeren. -->
      <Grid ColumnDefinitions="*,Auto,Auto">
        <StackPanel Spacing="4" VerticalAlignment="Center">
          <TextBlock Classes="pageTitle" Text="{l:Localize Hist_Title}" />
          <TextBlock Classes="muted" FontSize="13.5" Text="{Binding Summary}" />
        </StackPanel>
        <TextBox Grid.Column="1" Classes="field" Width="210" Height="42" CornerRadius="999"
                 VerticalContentAlignment="Center" VerticalAlignment="Bottom"
                 PlaceholderText="{l:Localize Hist_Search}" Text="{Binding Search}"
                 AutomationProperties.Name="{l:Localize Hist_Search}" />
        <Button Grid.Column="2" Classes="ghost coral" Height="42" Margin="10,0,0,0"
                VerticalAlignment="Bottom" Command="{Binding ClearCommand}"
                Content="{l:Localize Hist_Clear}"
                AutomationProperties.Name="{l:Localize Hist_Clear}" />
      </Grid>

      <!-- Ohne verdrahteten Verlaufsspeicher wird das offen ausgewiesen (Abschnitt 13.1). -->
      <Border Classes="insetRow" Background="{DynamicResource CoralSoftBrush}"
              IsVisible="{Binding !IsPersistent}">
        <TextBlock Classes="bodyText" Foreground="{DynamicResource CoralTextBrush}"
                   Text="{l:Localize Hist_NotPersistent}" />
      </Border>

      <!-- Leerzustand. -->
      <Border Background="{DynamicResource PaperBrush}" BorderBrush="{DynamicResource InkBrush}"
              BorderThickness="2" CornerRadius="24" Padding="44"
              IsVisible="{Binding IsEmpty}">
        <TextBlock Classes="muted" FontWeight="SemiBold" TextAlignment="Center"
                   HorizontalAlignment="Center" Text="{l:Localize Hist_Empty}" />
      </Border>

      <!-- Operationskarten. -->
      <ItemsControl ItemsSource="{Binding VisibleEntries}" IsVisible="{Binding !IsEmpty}"
                    AutomationProperties.Name="{l:Localize Hist_TableName}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Spacing="12" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:HistoryEntryViewModel">
            <Border Background="{DynamicResource PaperBrush}" BorderBrush="{DynamicResource InkBrush}"
                    BorderThickness="2" CornerRadius="20" Padding="20,16" BoxShadow="4 5 0 0 #E617140E"
                    AutomationProperties.Name="{Binding AccessibleSummary}">
              <Grid ColumnDefinitions="Auto,18,*,16,Auto,14,Auto,10,Auto" VerticalAlignment="Center">
                <Border Width="48" Height="48" CornerRadius="14" Background="{DynamicResource VioletSoftBrush}"
                        BorderBrush="{DynamicResource InkBrush}" BorderThickness="2">
                  <Path Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Stroke="{DynamicResource InkBrush}" StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round"
                        Data="M3,3 h18 v18 h-18 z M8.5,8.5 a1.6,1.6 0 1 1 0,0.01 M21,15 l-5,-5 L5,21" />
                </Border>

                <StackPanel Grid.Column="2" Spacing="5" VerticalAlignment="Center">
                  <TextBlock Text="{Binding FileName}" FontSize="15" FontWeight="Bold"
                             Foreground="{DynamicResource InkBrush}" TextTrimming="CharacterEllipsis" />
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Classes="monoNum" FontSize="12" Foreground="{DynamicResource MutedTextBrush}"
                               Text="{Binding Timestamp}" />
                    <Border CornerRadius="999" Padding="8,1" Background="{DynamicResource CanvasBrush}">
                      <TextBlock Classes="monoNum" FontSize="12" Foreground="{DynamicResource MutedTextBrush}"
                                 Text="{Binding EngineLabel}" />
                    </Border>
                  </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="4" HorizontalAlignment="Right" VerticalAlignment="Center">
                  <TextBlock Classes="monoNum" FontSize="13" HorizontalAlignment="Right"
                             Foreground="{DynamicResource MutedTextBrush}" Text="{Binding BeforeAfter}" />
                  <TextBlock Classes="monoNum" FontSize="16" FontWeight="Bold" HorizontalAlignment="Right"
                             Text="{Binding Savings}" />
                </StackPanel>

                <Border Grid.Column="6" Classes="badge mint" Padding="14,7" VerticalAlignment="Center">
                  <TextBlock Text="{Binding SavedText}" FontWeight="Bold" />
                </Border>

                <Button Grid.Column="8" Classes="ghost coral" Width="34" Height="34" Padding="0"
                        CornerRadius="11" VerticalAlignment="Center"
                        Command="{Binding DeleteCommand}"
                        ToolTip.Tip="{Binding DeleteAccessibleName}"
                        AutomationProperties.Name="{Binding DeleteAccessibleName}">
                  <Path Width="12" Height="12" Stretch="Uniform"
                        Stroke="{DynamicResource InkBrush}" StrokeThickness="2" StrokeLineCap="Round"
                        Data="M1,1 L11,11 M11,1 L1,11" />
                </Button>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

    </StackPanel>
  </ScrollViewer>
</UserControl>
